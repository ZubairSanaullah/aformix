PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb://<username>:<password>@cluster0.mongodb.net/aformix?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-secure-secret
CLIENT_URL=http://localhost:5173,https://aformix.vercel.app
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=hello@aformix.com
MAIL_PASS=<email-app-password>
# OPENAI_API_KEY=your-openai-api-key
CALENDLY_URL=https://calendly.com/aformix/discovery-call
CRM_PROVIDER=hubspot
CRM_API_KEY=replace-with-crm-api-key
CRM_CLIENT_ID=replace-with-client-id
CRM_CLIENT_SECRET=replace-with-client-secret
